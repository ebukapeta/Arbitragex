# ============================================================
# IMPORTANT — HOW TO USE THIS FILE
# ============================================================
# This file is named "gitignore.txt" because files starting
# with a dot (like .gitignore) are often hidden or excluded
# by download systems and file managers.
#
# TO USE IT:
# 1. Rename this file from "gitignore.txt" to ".gitignore"
#    (just add the dot at the front, remove the .txt extension)
#
# On Windows:
#   Right-click → Rename → type exactly:  .gitignore
#   Windows may warn you — click Yes
#
# On Mac/Linux terminal:
#   mv gitignore.txt .gitignore
#
# On Mac Finder:
#   Press Cmd+Shift+. to show hidden files
#   Then rename the file to .gitignore
#
# 2. Place the renamed .gitignore file in the ROOT of your
#    project folder (same level as package.json)
#
# 3. Done — Git will now use it automatically
# ============================================================


# --- Dependencies -------------------------------------------
# Generated by "npm install" — never commit this folder
# It can be 500MB+ and is fully regenerated from package.json
node_modules/


# --- Build output -------------------------------------------
# Generated by "npm run build" — Render builds this itself
# Never commit — it bloats your repo and gets regenerated
dist/
dist-ssr/


# --- Environment variables ----------------------------------
# NEVER commit these — they contain your real server secrets
# Copy .env.example → .env and fill in your values locally
.env
.env.local
.env.development.local
.env.test.local
.env.production.local


# --- Encrypted API key file ---------------------------------
# Auto-generated by the backend server at runtime
# Contains AES-256 encrypted exchange API credentials
# Never exists until the server runs for the first time
# NEVER commit this — it holds your encrypted trading keys
server/store/keys.enc


# --- Editor directories -------------------------------------
.vscode/
.idea/
*.swp
*.swo


# --- Operating system files ---------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db


# --- Logs ---------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log


# --- TypeScript build cache ---------------------------------
*.tsbuildinfo


# --- Utility files not needed in repo ----------------------
arbitragex-repo.zip
